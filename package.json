  "scripts": {
    "clean": "pnpm -r --sort run clean",
    "build": "pnpm -r --sort run build",
    "lint": "pnpm -r --sort run lint",
    "lint-fix": "pnpm -r --sort run lint-fix",
    "generate-docs": "pnpm -r --sort run typedoc",
    "test": "echo Starting full test && pnpm -r --sort run test",
    "test-coverage": "pnpm -r --sort run test-coverage",
    "apply-github-info": "./apply-github-info.sh",
    "set-codependencies-by-github-tag": "echo $GITHUB_RUN_NUMBER && ./set-codependencies-by-github-tag.sh 6.1.$GITHUB_RUN_NUMBER",
    "full-publish": "pnpm -r --sort run custom-publish"
  },
